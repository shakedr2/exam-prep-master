# Staging environment variables.
#
# Copy this file to `.env.staging` and fill in real values for the staging
# Supabase project (or Supabase preview branch). DO NOT commit `.env.staging`.
#
# Vite loads this file automatically when you run:
#   npm run build -- --mode staging
#   npm run dev -- --mode staging
#
# In Vercel, set these as Environment Variables scoped to the "Preview"
# environment (and optionally a dedicated "staging" Git branch). See
# STAGING_SETUP.md for the full runbook.

# --- Supabase (staging project or branch) -------------------------------------
# Use a SEPARATE Supabase project for staging, or a Supabase branch from the
# production project. Never point staging at production credentials.
VITE_SUPABASE_URL=https://your-staging-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_staging_anon_key
VITE_SUPABASE_PROJECT_ID=your_staging_project_ref

# --- Admin -------------------------------------------------------------------
# Use a non-personal address for staging so production admin does not leak in.
VITE_ADMIN_EMAIL=staging-admin@example.com

# --- Observability -----------------------------------------------------------
# Recommended: separate PostHog project + Sentry environment for staging so
# staging traffic does not pollute production dashboards.
VITE_POSTHOG_KEY=your_staging_posthog_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=your_staging_sentry_dsn

# --- Build-time flags --------------------------------------------------------
# Surface a "staging" badge in the UI and opt out of production-only behaviors.
VITE_APP_ENV=staging
