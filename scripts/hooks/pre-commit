#!/usr/bin/env bash
# pre-commit hook: scan staged files for secrets using TruffleHog.
# Install once per developer:
#   cp scripts/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Requires Docker to be running, OR the trufflehog binary to be on $PATH.
# Install binary: https://github.com/trufflesecurity/trufflehog#installation

set -e

# Collect staged files (Added/Copied/Modified) — staged changes are not yet
# in git history, so we use the filesystem scanner instead of the git scanner.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "🔍 Scanning staged files for secrets..."

if command -v trufflehog &>/dev/null; then
  # shellcheck disable=SC2086
  echo "$STAGED_FILES" | xargs trufflehog filesystem --only-verified --fail
elif command -v docker &>/dev/null; then
  # shellcheck disable=SC2086
  echo "$STAGED_FILES" | xargs -I{} \
    docker run --rm -v "$(pwd):/repo" trufflesecurity/trufflehog:latest \
    filesystem /repo/{} --only-verified --fail
else
  echo "⚠️  TruffleHog not found. Skipping secret scan."
  echo "   Install from: https://github.com/trufflesecurity/trufflehog#installation"
  exit 0
fi
