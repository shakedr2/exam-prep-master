VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_ADMIN_EMAIL=your_admin_email
VITE_POSTHOG_KEY=your_posthog_project_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=your_sentry_dsn
# One of: development | staging | production. Controls environment-specific UI
# (e.g. staging banner) and telemetry tags. See .env.staging.example.
VITE_APP_ENV=development

# --- Supabase Edge Function secrets (send-welcome-email, Phase 4 PR2) ---
# Set these via `supabase secrets set …`, NOT as Vite envs. Listed here for
# discoverability; values should never ship in the browser bundle.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Logic Flow <onboarding@resend.dev>
# APP_URL=https://logicflow.dev
# SUPABASE_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
# UNSUBSCRIBE_EMAIL=unsubscribe@logicflow.dev
